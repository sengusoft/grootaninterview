# Base URL (default: production Heroku app)
CONTACT_LIST_BASE_URL=https://thinking-tester-contact-list.herokuapp.com

# Optional: path to interview QR PNG (default: ./fixtures/reference-qr.png)
# If the file is missing, the suite bootstraps a new user and generates a matching QR.
REFERENCE_QR_PATH=

# Password applied after PATCH /users/me (default in tests: PlaywrightNewPass123!)
E2E_NEW_PASSWORD=PlaywrightNewPass123!

# Report comparison: baseline skips the marker; `npm run test:current` sets both below.
# RUN_PROFILE=baseline | current
# INCLUDE_REGRESSION_MARKER=1   (only with RUN_PROFILE=current — intentional failing test for compare-reports)
